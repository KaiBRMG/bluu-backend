# Dependencies
node_modules/

# Next.js
.next/
out/

electron/dist/
electron/node_modules/
electron/.cache/
# build-assets holds private keys, certs and their base64 exports (the raw
# material behind the MAC_CSC_LINK / APPLE_API_KEY_B64 secrets). Deny by
# default and allow back only the inert build inputs, so a new key or a
# base64 dump of one can never be committed by an extension we forgot.
electron/build-assets/**
!electron/build-assets/**/
!electron/build-assets/**/*.plist
!electron/build-assets/**/*.png

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env*
.env.local
.env.production

# OS files
.DS_Store
Thumbs.db

# Legacy folder with committed secrets — keep untracked
Delete/

functions/node_modules

.vercel

.claude
