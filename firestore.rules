rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: authenticated Firebase user only.
    // Domain enforcement happens at token issuance (exchange-code route),
    // so we do not repeat the email regex here — it costs a string match
    // on every rule evaluation and the token was already validated server-side.
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Check if the authenticated user has the 'admin' group.
    // Uses Custom JWT Claims set in the exchange-code route and refreshed
    // whenever group membership changes — $0 cost, no Firestore read required.
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // 1. Users collection
    // Client listener: hooks/useUserData.ts (onSnapshot users/{uid})
    // Admin panel reads other users' docs via the listener — needs isAdmin() bypass.
    // Writes: Admin SDK only (API routes bypass these rules)
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false;
    }

    // 2. Groups collection
    // No client-side listeners; read via API routes (Admin SDK).
    // Keeping a permissive read rule here in case a future client listener
    // needs it, but writes remain server-only.
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // 3. Page permissions collection
    // Client listener: hooks/useAdminData.ts (onSnapshot page-permissions)
    // Full collection read — authenticated users only.
    match /page-permissions/{pageId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // 4. Time entries
    // No client-side listeners currently. All reads/writes go through API routes
    // (Admin SDK). Rules defined here for defence-in-depth and future listeners.
    // Admin access to other users' entries is handled entirely via Admin SDK
    // in API routes, so we do not need an isAdmin() bypass here.
    match /time-entries/{entryId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // 5. Screenshots
    // Same pattern as time-entries.
    match /screenshots/{screenshotId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // 6. Active sessions (new session model)
    // Client-side onSnapshot used by useActiveUsers (admin panel).
    // User reads own doc; admin reads all. Writes via Admin SDK only.
    match /active_sessions/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow write: if false;
    }

    // 7. Time entries ledger (new session model)
    // All reads/writes via Admin SDK (API routes + Cloud Function).
    // User reads own completed sessions; admin reads all.
    match /time_entries/{sessionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // 8. Notifications
    // Client listener: hooks/useNotifications.tsx (onSnapshot notifications)
    // Users may only read their own notifications. Writes (mark-read, dismiss)
    // go through API routes (Admin SDK) so client write remains denied.
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // 9. Disputes
    // All writes via Admin SDK (API routes — bypass these rules entirely).
    // Users may read disputes they created or are assigned to.
    // Admins may read all disputes.
    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.assignedTo == request.auth.uid ||
        isAdmin()
      );
      allow write: if false;
    }

    // 10. Shifts
    // All reads/writes via Admin SDK (API routes). No client-side listeners.
    // Rule exists for defence-in-depth — denies any accidental direct client access.
    match /shifts/{shiftId} {
      allow read, write: if false;
    }

    // 11. Creators
    // All reads via Admin SDK (API routes). No client-side listeners.
    // Rule exists for defence-in-depth — denies any accidental direct client access.
    match /creators/{creatorId} {
      allow read, write: if false;
    }

    // 12. Bug reports
    // All writes via Admin SDK (API routes). No client-side access needed.
    // Rule exists for defence-in-depth — denies any accidental direct client writes.
    match /bugs/{bugId} {
      allow read, write: if false;
    }

    // 13. Leave requests
    // All writes via Admin SDK (API routes). Users may read their own leave requests.
    // Admins may read all. No direct client writes permitted.
    match /leave_requests/{leaveId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

  }
}
